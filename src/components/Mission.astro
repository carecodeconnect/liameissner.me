---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'de' } = Astro.props;
const copy = t(lang).mission;
---
<section class="section" id="wofur">
  <div class="kicker">{copy.kicker}</div>
  <h2 class="wofur-headline">{copy.headline}</h2>
</section>

<style>
  .wofur-headline {
    font-size: clamp(32px, 5.5vw, 60px);
    margin-bottom: clamp(24px, 4vw, 48px);
  }
</style>
