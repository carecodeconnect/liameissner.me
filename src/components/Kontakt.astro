---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'de' } = Astro.props;
const copy = t(lang).kontakt;
---
<section class="section" id="kontakt">
  <div class="kicker">{copy.kicker}</div>
  <div class="kontakt-head">
    <h3>{copy.headline}</h3>
    <p class="kontakt-intro">{copy.intro}</p>
  </div>

  <form
    class="kontakt-form"
    method="POST"
    action="https://api.web3forms.com/submit"
    data-toast-sending={copy.toast.sending}
    data-toast-success={copy.toast.success}
    data-toast-error={copy.toast.error}
  >
    {/* Web3Forms config — sends submissions to the email registered with the access key.
        To activate: register the email at https://web3forms.com,
        paste the access key below, then push. */}
    <input type="hidden" name="access_key" value="2618e74a-6da4-4d24-8e4f-c4e592587e04">
    <input type="hidden" name="subject" value={copy.web3FormsSubject}>
    <input type="hidden" name="from_name" value={copy.web3FormsFromName}>
    {/* Honeypot — bots typically fill every field; humans never see this one. */}
    <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off">

    <div class="form-row">
      <div class="form-field">
        <label class="form-label" for="f-name">{copy.labels.name} <span class="req">*</span></label>
        <input class="form-input" id="f-name" name="name" type="text" placeholder={copy.placeholders.name} required>
      </div>
      <div class="form-field">
        <label class="form-label" for="f-email">{copy.labels.email} <span class="req">*</span></label>
        <input class="form-input" id="f-email" name="email" type="email" placeholder={copy.placeholders.email} required>
      </div>
    </div>

    <div class="form-row">
      <div class="form-field">
        <label class="form-label" for="f-phone">{copy.labels.phone}</label>
        <input class="form-input" id="f-phone" name="phone" type="tel" placeholder={copy.placeholders.phone}>
      </div>
      <div class="form-field">
        <label class="form-label" for="f-org">{copy.labels.org}</label>
        <input class="form-input" id="f-org" name="org" type="text" placeholder={copy.placeholders.org}>
      </div>
    </div>

    <div class="form-field">
      <span class="form-label">{copy.labels.anliegen} <span class="req">*</span></span>
      <div class="chip-group" role="group" aria-label={copy.anliegenAria}>
        {copy.anliegen.map((a) => (
          <button type="button" class="chip" role="checkbox" aria-checked="false">{a}</button>
        ))}
      </div>
      <input type="hidden" name="anliegen" id="f-anliegen">
    </div>

    <div class="form-field">
      <label class="form-label" for="f-msg">{copy.labels.message} <span class="req">*</span></label>
      <textarea class="form-textarea" id="f-msg" name="message" placeholder={copy.placeholders.message} required></textarea>
    </div>

    <div class="form-footer">
      <span class="form-note">{copy.note}</span>
      <button type="submit" class="form-submit">{copy.submit}</button>
    </div>

    <div class="form-toast" role="status" aria-live="polite" data-state="idle"></div>
  </form>
</section>

<style>
  #kontakt {
    background: var(--paper-2);
    padding-top: clamp(60px, 8vw, 110px);
    padding-bottom: clamp(60px, 8vw, 110px);
  }
  #kontakt > :global(.kicker) { max-width: 880px; margin-left: auto; margin-right: auto; }
  .kontakt-head {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(16px, 2vw, 24px);
    align-items: start;
    max-width: 880px;
    margin: 0 auto clamp(32px, 4vw, 48px);
  }
  .kontakt-head :global(h3) {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(44px, 7vw, 80px);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .kontakt-intro {
    max-width: none;
    margin: 0;
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-2);
  }

  .kontakt-form {
    max-width: 880px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: clamp(18px, 2.2vw, 26px);
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(18px, 2.8vw, 36px);
  }
  .form-field { display: flex; flex-direction: column; gap: 8px; }
  .form-label {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-2);
    font-weight: 500;
  }
  .form-label :global(.req) { color: var(--accent); margin-left: 4px; font-weight: 400; }

  /* Inputs and textarea: borderless, defined by their paper fill against the
     section's paper-2 background. Focus/hover indicated by box-shadow rings. */
  .form-input,
  .form-textarea {
    font-family: var(--sans);
    font-size: 15px;
    line-height: 1.5;
    color: var(--ink);
    background: var(--paper);
    border: 0;
    border-radius: 4px;
    padding: 12px 16px;
    width: 100%;
    transition: box-shadow .2s, background .2s;
  }
  .form-input { height: 46px; }
  .form-textarea {
    resize: vertical;
    min-height: 140px;
    line-height: 1.55;
    padding: 14px 16px;
  }
  .form-input:hover,
  .form-textarea:hover {
    box-shadow: inset 0 0 0 1px rgba(26, 26, 26, 0.2);
  }
  .form-input:focus,
  .form-textarea:focus {
    outline: none;
    background: var(--paper);
    box-shadow: 0 0 0 2px var(--accent), 0 0 0 5px rgba(23, 71, 255, 0.15);
  }
  .form-input::placeholder,
  .form-textarea::placeholder {
    color: var(--muted);
    opacity: 0.7;
    font-style: italic;
  }

  /* Anliegen chips: borderless paper fill, single row at desktop widths,
     wrap on narrow viewports. Chips distribute across the full row so the
     first/last align flush with the textarea edges below. */
  .chip-group {
    display: flex;
    flex-wrap: nowrap;
    justify-content: space-between;
    gap: 6px;
  }
  .chip {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
    color: var(--ink);
    background: var(--paper);
    border: 0;
    border-radius: 4px;
    padding: 10px 14px;
    cursor: pointer;
    transition: box-shadow .2s, background .2s, color .2s;
  }
  .chip:hover {
    box-shadow: inset 0 0 0 1px var(--ink);
  }
  .chip:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .chip:global(.is-selected) {
    background: var(--accent);
    color: var(--paper);
    box-shadow: none;
  }

  .form-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    margin-top: clamp(8px, 1.2vw, 16px);
  }
  .form-note {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .form-submit {
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    background: var(--ink);
    color: var(--paper);
    border: 0;
    padding: 14px 24px;
    cursor: pointer;
    transition: background .2s, color .2s;
  }
  .form-submit:hover { background: var(--accent); }
  .form-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    background: var(--ink);
  }

  /* Submission feedback — hidden until JS sets data-state to sending/success/error */
  .form-toast {
    font-family: var(--sans);
    font-size: 14px;
    line-height: 1.5;
    padding: 12px 16px;
    border-radius: 4px;
    margin-top: 4px;
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition: opacity .2s, max-height .2s, padding .2s, margin-top .2s;
    padding-top: 0;
    padding-bottom: 0;
  }
  .form-toast[data-state="sending"],
  .form-toast[data-state="success"],
  .form-toast[data-state="error"] {
    opacity: 1;
    max-height: 200px;
    padding-top: 12px;
    padding-bottom: 12px;
    margin-top: 4px;
  }
  .form-toast[data-state="sending"] { background: var(--paper); color: var(--ink-2); }
  .form-toast[data-state="success"] { background: var(--accent); color: var(--paper); }
  .form-toast[data-state="error"]   { background: var(--paper); color: var(--ink); box-shadow: inset 0 0 0 1px var(--accent); }
  .form-toast a { color: var(--accent); text-decoration: underline; }
  .form-toast a:hover { text-decoration: none; }

  /* Chips wrap on viewports below ~880px (form no longer at full max-width) */
  @media (max-width: 880px) {
    .chip-group {
      flex-wrap: wrap;
      justify-content: flex-start;
      gap: 8px;
    }
  }
  @media (max-width: 700px) {
    .form-row { grid-template-columns: 1fr; gap: clamp(18px, 4vw, 24px); }
    .form-footer { flex-direction: column; align-items: stretch; }
    .form-submit { width: 100%; }
  }
</style>
