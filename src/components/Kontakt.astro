---
const anliegen = [
  'Foresight Studie',
  'Lehre',
  'Keynote',
  'Workshop',
  '1:1 Coaching',
  'Presse / Medien',
  'Anderes',
];
---
<section class="section" id="kontakt">
  <div class="kicker">SAG HALLO</div>
  <div class="kontakt-head">
    <h3>Schreib mir.</h3>
    <p class="kontakt-intro">
      Schreib mir, wenn du mit mir arbeiten möchtest — als Organisation, als Einzelperson, oder als Teil dessen, was Heartfelt Futures werden wird.
    </p>
  </div>

  <form class="kontakt-form" method="post" action="#" novalidate>
    <div class="form-row">
      <div class="form-field">
        <label class="form-label" for="f-name">Name <span class="req">*</span></label>
        <input class="form-input" id="f-name" name="name" type="text" required>
      </div>
      <div class="form-field">
        <label class="form-label" for="f-email">E-Mail <span class="req">*</span></label>
        <input class="form-input" id="f-email" name="email" type="email" required>
      </div>
    </div>

    <div class="form-row">
      <div class="form-field">
        <label class="form-label" for="f-phone">Telefon</label>
        <input class="form-input" id="f-phone" name="phone" type="tel">
      </div>
      <div class="form-field">
        <label class="form-label" for="f-org">Organisation</label>
        <input class="form-input" id="f-org" name="org" type="text">
      </div>
    </div>

    <div class="form-field">
      <span class="form-label">Anliegen <span class="req">*</span></span>
      <div class="chip-group" role="radiogroup" aria-label="Anliegen">
        {anliegen.map((a) => (
          <button type="button" class="chip" role="radio" aria-checked="false">{a}</button>
        ))}
      </div>
      <input type="hidden" name="anliegen" id="f-anliegen">
    </div>

    <div class="form-field">
      <label class="form-label" for="f-msg">Nachricht <span class="req">*</span></label>
      <textarea class="form-textarea" id="f-msg" name="message" required></textarea>
    </div>

    <div class="form-footer">
      <span class="form-note">* Pflichtfelder · Daten gemäß DSGVO</span>
      <button type="submit" class="form-submit">Nachricht senden →</button>
    </div>
  </form>

  <div class="kontakt-direct">
    <span class="kicker">Oder direkt</span>
    <a href="mailto:hallo@liameissner.de">E-Mail</a>
    <a href="#">Newsletter</a>
    <a href="#">LinkedIn</a>
    <a href="#">Instagram</a>
    <a href="#">Substack</a>
  </div>
</section>

<style>
  #kontakt {
    background: var(--paper-2);
    padding-top: clamp(80px, 12vw, 160px);
    padding-bottom: clamp(80px, 12vw, 160px);
  }
  #kontakt > :global(.kicker) { max-width: 880px; margin-left: auto; margin-right: auto; }
  .kontakt-head {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(24px, 3vw, 36px);
    align-items: start;
    max-width: 880px;
    margin: 0 auto clamp(56px, 7vw, 88px);
  }
  .kontakt-head :global(h3) {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(56px, 9vw, 120px);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .kontakt-intro {
    max-width: 52ch;
    margin: 0;
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink-2);
  }

  .kontakt-form {
    max-width: 880px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: clamp(28px, 3.4vw, 40px);
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(28px, 4vw, 56px);
  }
  .form-field { display: flex; flex-direction: column; gap: 14px; }
  .form-label {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-2);
    font-weight: 500;
  }
  .form-label :global(.req) { color: var(--accent); margin-left: 4px; font-weight: 400; }
  .form-input,
  .form-textarea {
    font-family: var(--sans);
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink);
    background: transparent;
    border: 0;
    border-bottom: 1px solid rgba(26, 26, 26, 0.25);
    padding: 10px 0;
    width: 100%;
    transition: border-color .2s;
  }
  .form-input { height: 44px; }
  .form-textarea { resize: vertical; min-height: 180px; line-height: 1.6; }
  .form-input:focus,
  .form-textarea:focus { outline: none; border-bottom-color: var(--ink); }
  .form-input::placeholder,
  .form-textarea::placeholder { color: var(--muted); opacity: 0.55; }

  .chip-group {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .chip {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    background: transparent;
    border: 1px solid rgba(26, 26, 26, 0.25);
    padding: 12px 18px;
    cursor: pointer;
    transition: border-color .2s, background .2s, color .2s;
  }
  .chip:hover { border-color: var(--ink); }
  .chip:global(.is-selected) {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--paper);
  }

  .form-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    border-top: 1px solid rgba(26, 26, 26, 0.25);
    padding-top: clamp(24px, 3vw, 32px);
  }
  .form-note {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .form-submit {
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    background: var(--ink);
    color: var(--paper);
    border: 0;
    padding: 18px 28px;
    cursor: pointer;
    transition: background .2s, color .2s;
  }
  .form-submit:hover { background: var(--accent); }

  .kontakt-direct {
    margin: clamp(48px, 6vw, 72px) auto 0;
    max-width: 880px;
    padding-top: clamp(24px, 3vw, 32px);
    border-top: 1px solid rgba(26, 26, 26, 0.25);
    display: flex;
    flex-wrap: wrap;
    gap: 8px 28px;
    align-items: baseline;
  }
  .kontakt-direct :global(.kicker) { margin-bottom: 0; margin-right: 8px; }
  .kontakt-direct :global(a) {
    font-family: var(--sans);
    font-size: 14px;
    color: var(--ink);
    border-bottom: 1px solid var(--rule-soft);
    padding-bottom: 2px;
  }
  .kontakt-direct :global(a:hover) { border-bottom-color: var(--accent); color: var(--accent); }

  @media (max-width: 700px) {
    .form-row { grid-template-columns: 1fr; gap: clamp(24px, 5vw, 32px); }
    .form-footer { flex-direction: column; align-items: stretch; }
    .form-submit { width: 100%; }
  }
</style>
