---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'de' } = Astro.props;
const copy = t(lang).pillars;
const pillars = copy.items;

// Auto-add target/rel for off-site links so we don't have to repeat it inline.
const ext = (href: string) =>
  /^https?:\/\//.test(href) ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---
<section class="section pillars-section" id="arbeit">
  <div class="kicker">{copy.kicker}</div>
  <div class="pillars">
    {pillars.map((p) => (
      <article class="pillar" data-open="false">
        <button class="pillar-head" aria-controls={`${p.id}-body`} aria-expanded="false">
          <span class="pillar-num">{p.num}</span>
          <span class="pillar-title">{p.title}</span>
          <span class="pillar-blurb" set:html={p.blurb}></span>
          <span class="pillar-toggle" aria-hidden="true">+</span>
        </button>
        <div class="pillar-body" id={`${p.id}-body`}>
          <div class="pillar-body-inner">
            <div class="pillar-body-content">
              <span class="spacer"></span>
              <div>
                <h4>{p.intro.heading}</h4>
                <p>{p.intro.body}</p>
                {p.pubs && (
                  <>
                    <div class="kicker pubs-kicker">{copy.pubsKicker}</div>
                    <ul class="pubs">
                      {p.pubs.map((pub) => (
                        <li>
                          <span><em>{pub.title}</em></span>
                          <span class="year">{pub.year}</span>
                        </li>
                      ))}
                    </ul>
                  </>
                )}
                {p.pubsLink && (
                  <a class="link offer-link pubs-link" href={p.pubsLink.href} {...ext(p.pubsLink.href)}>{p.pubsLink.label}</a>
                )}
              </div>
              <div>
                {p.offers.map((o) => (
                  <div class="offer">
                    <h4>{o.title}</h4>
                    <p>{o.body}</p>
                    <a class="link offer-link" href={o.link.href} {...ext(o.link.href)}>{o.link.label}</a>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .pillars-section { padding-top: 0; }
  .pillars { border-top: 2px solid var(--rule); }
  .pillar { border-bottom: 1px solid var(--rule); }

  .pillar-head {
    display: grid;
    grid-template-columns: 110px 1fr 1fr 56px;
    gap: clamp(16px, 3vw, 40px);
    padding: clamp(28px, 4vw, 48px) 0;
    align-items: start;
    background: transparent;
    border: 0;
    width: 100%;
    text-align: left;
    font-family: inherit;
    color: inherit;
    cursor: pointer;
    transition: background .35s;
  }
  .pillar-head:hover { background: var(--accent-soft); }
  .pillar-head:focus-visible { outline: 2px solid var(--accent); outline-offset: -2px; }

  .pillar-num {
    font-family: var(--serif);
    font-size: clamp(36px, 5vw, 60px);
    color: var(--accent);
    line-height: 0.9;
  }
  .pillar-title {
    font-family: var(--serif);
    font-size: clamp(32px, 5.4vw, 72px);
    white-space: nowrap;
    line-height: 0.95;
    letter-spacing: -0.01em;
  }
  .pillar-blurb {
    font-family: var(--sans);
    font-size: clamp(15px, 1.2vw, 17px);
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
    color: var(--ink-2);
    padding-top: 16px;
    line-height: 1.5;
    max-width: 44ch;
  }
  .pillar-toggle {
    font-family: var(--sans);
    font-weight: 400;
    font-size: 48px;
    text-align: right;
    padding-top: 4px;
    color: var(--ink);
    transition: transform .4s ease, color .3s;
    line-height: 1;
  }
  .pillar[data-open="true"] .pillar-toggle { transform: rotate(45deg); color: var(--accent); }
  .pillar[data-open="true"] .pillar-num { font-style: italic; }

  .pillar-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows .5s cubic-bezier(.4, 0, .2, 1);
  }
  .pillar[data-open="true"] .pillar-body { grid-template-rows: 1fr; }
  .pillar-body-inner { overflow: hidden; }
  .pillar-body-content {
    padding: 0 0 clamp(40px, 5vw, 64px) 0;
    display: grid;
    grid-template-columns: 110px 1fr 1fr 56px;
    gap: clamp(20px, 3vw, 40px);
  }
  .pillar-body-content > .spacer { display: block; }
  /* Sub-headings inside the accordion bodies: Inter Semibold (600) instead of
     Instrument Serif Regular, because Instrument Serif ships in one weight only
     and faux-bold looks rough. Sans bold gives a clean typographic step. */
  .pillar-body-content :global(h4) {
    font-family: var(--sans);
    font-size: 19px;
    margin: 0 0 10px 0;
    font-weight: 600;
    letter-spacing: 0;
  }
  .pillar-body-content :global(p) {
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink-2);
    max-width: 52ch;
  }
  .offer { margin-bottom: 32px; }
  .offer-link {
    display: inline-block;
    margin-top: 4px;
    font-size: 13px;
    font-family: var(--sans);
    letter-spacing: 0.04em;
  }
  .pubs-kicker { margin-top: 36px; margin-bottom: 12px; }
  .pubs-link { margin-top: 16px; }
  .pubs {
    max-width: 480px;
  }
  .pubs :global(li) {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    padding: 10px 0;
    border-top: 1px solid var(--rule-soft);
    font-size: 14px;
    line-height: 1.4;
  }
  .pubs :global(li:last-child) { border-bottom: 1px solid var(--rule-soft); }
  .pubs :global(.year) { color: var(--muted); }

  @media (max-width: 880px) {
    .pillar-head,
    .pillar-body-content {
      grid-template-columns: 1fr;
    }
    .pillar-blurb { padding-top: 8px; }
    .pillar-toggle { text-align: left; }
    .pillar-body-content > .spacer { display: none; }
  }
</style>
