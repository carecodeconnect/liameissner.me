---
type Offer = { title: string; body: string; link: { href: string; label: string } };
type Pillar = {
  num: string;
  id: string;
  title: string;
  blurb: string;
  intro: { heading: string; body: string };
  pubs?: { title: string; year: string }[];
  pubsLink?: { href: string; label: string };
  offers: Offer[];
};

const pillars: Pillar[] = [
  {
    num: '01',
    id: 'p1',
    title: 'Strategic Foresight',
    blurb:
      'Strategie braucht Klarheit und die kommt aus guter Analyse und gekonnter Antizipation. Ich praktiziere und Lehre Foresight-Methoden und berate mit Freude und Präsenz. Unternehmen, Ministerien und innovative Projekte.',
    intro: {
      heading: 'Foresight-Arbeit',
      body: 'Seit über sieben Jahren arbeite ich als wissenschaftliche Foresight-Praktikerin — am Fraunhofer ISI, bei VDI/VDE Innovation + Technik und als selbstständige Beraterin. Im Zentrum steht nicht Vorhersage, sondern Sensemaking: Annahmen prüfen, blinde Flecken aufdecken, tragfähige Optionen entwickeln.',
    },
    pubs: [
      { title: '7 Foresight-Methoden zur erfolgreichen Strategieentwicklung', year: '2024' },
      { title: 'Gesellschaftliche Auswirkungen hybrider Arbeitsformen · TAB', year: '2024' },
      { title: 'Seltene Erden: Rohstoffsicherung in Europa · TAB', year: '2024' },
      { title: 'Innovative Schiffbaukonzepte · TAB', year: '2022' },
    ],
    pubsLink: { href: '#', label: 'Vollständige Publikationsliste auf ResearchGate ↗' },
    offers: [
      {
        title: 'Angewandte Zukunftsforschung',
        body: 'Forschungs- und Strategieprojekte für Organisationen mit komplexen Zukunftsfragen. Erfahrung u. a. mit Bundesministerien, Bundestags-TAB, Umweltbundesamt, Stiftungen, NGOs.',
        link: { href: '#kontakt', label: '→ Projekt anfragen' },
      },
      {
        title: 'Keynotes',
        body: 'Vorträge zu Foresight, Zukunftsangst, alternativen Zukünften und verkörperter Zukunftsforschung — für Konferenzen, Strategie-Klausuren und Hochschulen.',
        link: { href: '#kontakt', label: '→ Keynote anfragen' },
      },
      {
        title: 'Foresight-Weiterbildung',
        body: 'Ich lehre Foresight an der FU Berlin und biete maßgeschneiderte Trainings für Organisationen an — vom eintägigen Crashkurs bis zum mehrteiligen Curriculum.',
        link: { href: '#kontakt', label: '→ Weiterbildung anfragen' },
      },
    ],
  },
  {
    num: '02',
    id: 'p2',
    title: 'Systemic Therapy',
    blurb:
      'Wohin mit all dem verdammten Schmerz?! Veränderung kann richtig weh tun. Krise, Krankheit, Burnout, der Verlust eines Menschen oder eines Gewissheit. Du musst da nicht alleine durch. Genau dafür habe ich das Life Repair Kit gegründet.',
    intro: {
      heading: 'Systemische Begleitung',
      body: 'Ich bin ausgebildete systemische Beraterin und Therapeutin und arbeite mit Menschen in tiefgreifenden Übergängen. Meine Arbeit verbindet systemisches Denken, Embodiment, Nervensystem-Regulation und Resilienzforschung — nicht für schnelles Funktionieren, sondern für tragfähiges Wieder-Aufbauen.',
    },
    offers: [
      {
        title: '1:1 Coaching',
        body: 'Einzelsitzungen bei Burnout, Long Covid, Trennung, Trauer, Berufs- und Sinnkrisen.',
        link: { href: '#kontakt', label: '→ Termin buchen' },
      },
      {
        title: 'Life Repair Kit',
        body: 'Ein integratives Werkzeug für Menschen nach Krise — mit Praktiken für Körper, Nervensystem, Beziehungen und Sinn.',
        link: { href: '#kontakt', label: '→ Webseite besuchen' },
      },
      {
        title: 'Resilienz-Workshops',
        body: 'Für Teams und Organisationen. Burnout entsteht in Strukturen — genau dort setzen meine Workshops an.',
        link: { href: '#kontakt', label: '→ Workshop anfragen' },
      },
    ],
  },
  {
    num: '03',
    id: 'p3',
    title: 'Speculative Design',
    blurb:
      '„There is no alternative" ist eine der größten Lügen unserer Zeit. Es gibt andere Zukünfte — und wir können sie gemeinsam erschaffen. In meinem Studio Heartfelt Futures entwickle ich — allein und im Werden eines Kollektivs — Bilder, Räume und Praktiken alternativer Zukünfte, die um Liebe, Care und Zugehörigkeit gebaut sind.',
    intro: {
      heading: 'Heartfelt Futures Studio',
      body: 'Hier entstehen Bilder, Räume und Workshops, die Foresight mit Gestaltung und körperlicher Praxis verbinden. Wo andere Zukunftsforschung in Reports endet, fängt meine Arbeit an: bei der Frage, wie sich eine Zukunft anfühlen würde, in der wir gut leben.',
    },
    offers: [
      {
        title: 'Speculative Design Studio',
        body: 'Bilder, Objekte, Texte und Räume, die alternative Zukünfte sichtbar machen. Aufträge möglich für Organisationen, Stiftungen und Institutionen.',
        link: { href: '#kontakt', label: '→ Anfrage' },
      },
      {
        title: 'Visioning-Workshops',
        body: 'Zukünfte werden hier nicht am Whiteboard entworfen, sondern mit Körper, Material und Imagination. Foresight trifft Speculative Design.',
        link: { href: '#kontakt', label: '→ Workshop anfragen' },
      },
      {
        title: 'Heartfelt Futures Kollektiv',
        body: 'Ein Kollektiv aus Menschen, die an der Schnittstelle von Care, Foresight und Gestaltung arbeiten wollen.',
        link: { href: '#kontakt', label: '→ Mitmachen' },
      },
    ],
  },
];
---
<section class="section pillars-section" id="arbeit">
  <div class="kicker">MEINE ARBEIT</div>
  <div class="pillars">
    {pillars.map((p) => (
      <article class="pillar" data-open="false">
        <button class="pillar-head" aria-controls={`${p.id}-body`} aria-expanded="false">
          <span class="pillar-num">{p.num}</span>
          <span class="pillar-title">{p.title}</span>
          <span class="pillar-blurb">{p.blurb}</span>
          <span class="pillar-toggle" aria-hidden="true">+</span>
        </button>
        <div class="pillar-body" id={`${p.id}-body`}>
          <div class="pillar-body-inner">
            <div class="pillar-body-content">
              <span class="spacer"></span>
              <div>
                <h4>{p.intro.heading}</h4>
                <p>{p.intro.body}</p>
                {p.pubs && (
                  <>
                    <div class="kicker pubs-kicker">Veröffentlichungen (Auswahl)</div>
                    <ul class="pubs">
                      {p.pubs.map((pub) => (
                        <li>
                          <span><em>{pub.title}</em></span>
                          <span class="year">{pub.year}</span>
                        </li>
                      ))}
                    </ul>
                  </>
                )}
                {p.pubsLink && (
                  <a class="link offer-link pubs-link" href={p.pubsLink.href}>{p.pubsLink.label}</a>
                )}
              </div>
              <div>
                {p.offers.map((o) => (
                  <div class="offer">
                    <h4>{o.title}</h4>
                    <p>{o.body}</p>
                    <a class="link offer-link" href={o.link.href}>{o.link.label}</a>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .pillars-section { padding-top: 0; }
  .pillars { border-top: 2px solid var(--rule); }
  .pillar { border-bottom: 1px solid var(--rule); }

  .pillar-head {
    display: grid;
    grid-template-columns: 110px 1fr 1fr 56px;
    gap: clamp(16px, 3vw, 40px);
    padding: clamp(28px, 4vw, 48px) 0;
    align-items: start;
    background: transparent;
    border: 0;
    width: 100%;
    text-align: left;
    font-family: inherit;
    color: inherit;
    cursor: pointer;
    transition: background .35s;
  }
  .pillar-head:hover { background: var(--accent-soft); }
  .pillar-head:focus-visible { outline: 2px solid var(--accent); outline-offset: -2px; }

  .pillar-num {
    font-family: var(--serif);
    font-size: clamp(36px, 5vw, 60px);
    color: var(--accent);
    line-height: 0.9;
  }
  .pillar-title {
    font-family: var(--serif);
    font-size: clamp(32px, 5.4vw, 72px);
    white-space: nowrap;
    line-height: 0.95;
    letter-spacing: -0.01em;
  }
  .pillar-blurb {
    font-family: var(--sans);
    font-size: clamp(15px, 1.2vw, 17px);
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
    color: var(--ink-2);
    padding-top: 16px;
    line-height: 1.5;
    max-width: 44ch;
  }
  .pillar-toggle {
    font-family: var(--sans);
    font-weight: 400;
    font-size: 32px;
    text-align: right;
    padding-top: 4px;
    color: var(--ink);
    transition: transform .4s ease, color .3s;
    line-height: 1;
  }
  .pillar[data-open="true"] .pillar-toggle { transform: rotate(45deg); color: var(--accent); }
  .pillar[data-open="true"] .pillar-num { font-style: italic; }

  .pillar-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows .5s cubic-bezier(.4, 0, .2, 1);
  }
  .pillar[data-open="true"] .pillar-body { grid-template-rows: 1fr; }
  .pillar-body-inner { overflow: hidden; }
  .pillar-body-content {
    padding: 0 0 clamp(40px, 5vw, 64px) 0;
    display: grid;
    grid-template-columns: 110px 1fr 1fr 56px;
    gap: clamp(20px, 3vw, 40px);
  }
  .pillar-body-content > .spacer { display: block; }
  .pillar-body-content :global(h4) {
    font-family: var(--serif);
    font-size: 22px;
    margin: 0 0 10px 0;
    font-weight: 400;
  }
  .pillar-body-content :global(p) {
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink-2);
    max-width: 52ch;
  }
  .offer { margin-bottom: 32px; }
  .offer-link {
    display: inline-block;
    margin-top: 4px;
    font-size: 13px;
    font-family: var(--sans);
    letter-spacing: 0.04em;
  }
  .pubs-kicker { margin-top: 36px; margin-bottom: 12px; }
  .pubs-link { margin-top: 16px; }
  .pubs :global(li) {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 10px 0;
    border-top: 1px solid var(--rule-soft);
    font-size: 14px;
    line-height: 1.4;
  }
  .pubs :global(li:last-child) { border-bottom: 1px solid var(--rule-soft); }
  .pubs :global(.year) { color: var(--muted); flex-shrink: 0; }

  @media (max-width: 880px) {
    .pillar-head { grid-template-columns: 60px 1fr 30px; }
    .pillar-blurb { display: none; }
    .pillar-body-content { grid-template-columns: 1fr; }
    .pillar-body-content > .spacer { display: none; }
  }
</style>
