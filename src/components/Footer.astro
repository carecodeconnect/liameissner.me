---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'de' } = Astro.props;
const fullCopy = t(lang);
const copy = fullCopy.footer;
const brand = fullCopy.brand;
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="footer-grid">
    <span class="footer-brand-name">{brand}</span>
    <div class="footer-social" aria-label={copy.socialLabel}>
      <a href="https://www.linkedin.com/in/liameissner/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <svg viewBox="0 0 448 512" aria-hidden="true" focusable="false"><path d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3zM447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2-48.29 0-55.69 37.7-55.69 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.69-48.3 87.88-48.3 94 0 111.28 61.9 111.28 142.3V448z"/></svg>
      </a>
      <a href="https://substack.com/@heartfeltfutures" target="_blank" rel="noopener noreferrer" aria-label="Substack">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M22.54 8.24H1.46V5.4h21.08v2.84zM1.46 10.81V24L12 18.11 22.54 24V10.81H1.46zM22.54 0H1.46v2.84h21.08V0z"/></svg>
      </a>
    </div>
  </div>

  <hr class="footer-divider" />

  <div class="footer-bottom">
    <span>© {brand} {year}</span>
    <nav class="footer-legal" aria-label={copy.legalAria}>
      {copy.legal.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
  </div>
</footer>

<style>
  /* Dark footer — inverted from the cream body. Light text on ink ground,
     social icons flip to light circles. */
  .footer {
    padding: clamp(48px, 6vw, 80px) var(--pad-x) clamp(24px, 3vw, 32px);
    font-family: var(--sans);
    background: var(--ink);
    color: rgba(243, 239, 230, 0.6);
  }
  /* Constrained to the same 880px max-width as the contact form above,
     so the footer's left and right edges line up with the form fields.
     Brand name sits left, social icons right-aligned on the same baseline. */
  .footer-grid {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(20px, 3vw, 40px);
    flex-wrap: wrap;
    max-width: 880px;
    margin: 0 auto;
    padding-bottom: clamp(32px, 4vw, 48px);
  }
  .footer-brand-name {
    font-family: var(--serif);
    font-size: clamp(24px, 2.4vw, 32px);
    color: var(--paper);
    letter-spacing: 0;
  }

  /* Round social icons — light circles on dark ground, accent fill on hover. */
  .footer-social {
    display: flex;
    gap: 10px;
  }
  .footer-social :global(a) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--paper);
    color: var(--ink);
    transition: background .15s ease, color .15s ease;
  }
  .footer-social :global(a:hover) {
    background: var(--accent);
    color: var(--paper);
  }
  .footer-social :global(svg) {
    width: 16px;
    height: 16px;
    fill: currentColor;
    display: block;
  }

  /* Full-width hairline — light tone on the dark ground. */
  .footer-divider {
    border: 0;
    border-top: 1px solid rgba(243, 239, 230, 0.18);
    margin: 0;
    width: 100%;
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    max-width: 880px;
    margin: 0 auto;
    padding-top: clamp(16px, 2vw, 24px);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(243, 239, 230, 0.55);
  }
  .footer-legal {
    display: flex;
    gap: clamp(16px, 2vw, 24px);
  }
  .footer-legal :global(a) {
    color: rgba(243, 239, 230, 0.55);
    transition: color .15s ease;
  }
  .footer-legal :global(a:hover) { color: var(--accent); }

  @media (max-width: 480px) {
    .footer-bottom { flex-direction: column; align-items: flex-start; gap: 10px; }
  }
</style>
