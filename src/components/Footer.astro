---
const year = new Date().getFullYear();
const legalLinks = [
  { href: '#', label: 'Impressum' },
  { href: '#', label: 'Datenschutz' },
];
---
<footer class="footer">
  <div class="footer-grid">
    <span class="footer-brand-name">Lia Meißner</span>
    <div class="footer-social" aria-label="Soziale Medien">
      <a href="https://www.linkedin.com/in/liameissner/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zm1.78 13.02H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45C23.2 24 24 23.23 24 22.27V1.73C24 .77 23.2 0 22.22 0z"/></svg>
      </a>
      <a href="https://liameissner.substack.com/" target="_blank" rel="noopener noreferrer" aria-label="Substack">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M22.54 8.24H1.46V5.4h21.08v2.84zM1.46 10.81V24L12 18.11 22.54 24V10.81H1.46zM22.54 0H1.46v2.84h21.08V0z"/></svg>
      </a>
    </div>
  </div>

  <hr class="footer-divider" />

  <div class="footer-bottom">
    <span>© Lia Meißner {year}</span>
    <nav class="footer-legal" aria-label="Rechtliches">
      {legalLinks.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
  </div>
</footer>

<style>
  .footer {
    padding: clamp(48px, 6vw, 80px) var(--pad-x) clamp(24px, 3vw, 32px);
    font-family: var(--sans);
    color: var(--ink-2);
  }
  /* Constrained to the same 880px max-width as the contact form above,
     so the footer's left and right edges line up with the form fields.
     Brand name sits left, social icons right-aligned on the same baseline. */
  .footer-grid {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(20px, 3vw, 40px);
    flex-wrap: wrap;
    max-width: 880px;
    margin: 0 auto;
    padding-bottom: clamp(32px, 4vw, 48px);
  }
  .footer-brand-name {
    font-family: var(--serif);
    font-size: clamp(24px, 2.4vw, 32px);
    color: var(--ink);
    letter-spacing: 0;
  }

  /* Round social icons — solid ink circles, accent fill on hover. */
  .footer-social {
    display: flex;
    gap: 10px;
  }
  .footer-social :global(a) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--ink);
    color: var(--paper);
    transition: background .15s ease, transform .15s ease;
  }
  .footer-social :global(a:hover) { background: var(--accent); }
  .footer-social :global(svg) {
    width: 16px;
    height: 16px;
    fill: currentColor;
    display: block;
  }

  /* Full-width hairline — spans the section content area (viewport minus pad-x),
     not limited to the 880px form-aligned column below. */
  .footer-divider {
    border: 0;
    border-top: 1px solid var(--rule-soft);
    margin: 0;
    width: 100%;
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    max-width: 880px;
    margin: 0 auto;
    padding-top: clamp(16px, 2vw, 24px);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .footer-legal {
    display: flex;
    gap: clamp(16px, 2vw, 24px);
  }
  .footer-legal :global(a) {
    color: var(--muted);
    transition: color .15s ease;
  }
  .footer-legal :global(a:hover) { color: var(--accent); }

  @media (max-width: 480px) {
    .footer-bottom { flex-direction: column; align-items: flex-start; gap: 10px; }
  }
</style>
