---
import { Image } from 'astro:assets';
import heroImg from '../assets/hero.jpg';
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'de' } = Astro.props;
const copy = t(lang).hero;
---
<section class="hero">
  <div>
    <h1 class="hero-display">
      {copy.headlineLines.map((line, i) => (
        <>
          <span class:list={[{ ital: line.italic, accent: line.accent }]}>{line.text}</span>
          {i < copy.headlineLines.length - 1 && <br />}
        </>
      ))}
    </h1>
    <p class="hero-intro">{copy.intro}</p>
  </div>
  <div class="hero-img-wrap">
    <div class="hero-img">
      <Image
        src={heroImg}
        alt={copy.imageAlt}
        widths={[480, 768, 1024, 1280, 1600]}
        sizes="(max-width: 880px) 100vw, 45vw"
        format="webp"
        quality={85}
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <p class="hero-img-caption" set:html={copy.captionHtml}></p>
  </div>
</section>

<style>
  .hero {
    padding: clamp(40px, 6vw, 80px) var(--pad-x) clamp(60px, 8vw, 100px);
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: clamp(28px, 5vw, 56px);
    align-items: start;
  }
  .hero-display {
    margin-top: clamp(20px, 3vw, 36px);
    font-family: var(--serif);
    font-size: clamp(72px, 13vw, 176px);
    line-height: 0.86;
    letter-spacing: -0.022em;
  }
  .hero-display :global(.ital) { font-style: italic; }
  .hero-display :global(.accent) { color: var(--accent); }
  .hero-intro {
    margin-top: clamp(24px, 4vw, 40px);
    max-width: 480px;
    font-size: clamp(15px, 1.3vw, 18px);
    line-height: 1.55;
    color: var(--ink-2);
  }
  .hero-img-wrap { display: flex; flex-direction: column; gap: 12px; }
  .hero-img {
    width: 100%;
    aspect-ratio: 4 / 5;
    background: var(--paper-2);
    position: relative;
    overflow: hidden;
  }
  .hero-img :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .hero-img-caption {
    margin: 0;
    max-width: none;
    font-size: 12px;
    line-height: 1.5;
    letter-spacing: 0.04em;
    color: var(--muted);
  }
  @media (max-width: 880px) {
    .hero { grid-template-columns: 1fr; }
    .hero-img { aspect-ratio: 3 / 4; }
  }
</style>
