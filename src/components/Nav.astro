---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'de' } = Astro.props;
const copy = t(lang);
---
<header class="nav" id="top">
  <div class="nav-inner">
    <a href="#top" class="brand">{copy.brand}</a>
    <div class="nav-right">
      <nav class="nav-links" aria-label={copy.nav.hauptnavLabel}>
        {copy.nav.links.map((l) => <a href={l.href}>{l.label}</a>)}
      </nav>
      <div class="nav-lang" role="group" aria-label={lang === 'de' ? 'Sprache' : 'Language'}>
        {lang === 'de' ? (
          <span class="nav-lang-btn is-active" aria-current="page">DE</span>
        ) : (
          <a href="/" class="nav-lang-btn" data-lang-switch aria-label="Zur deutschen Version wechseln">DE</a>
        )}
        {lang === 'en' ? (
          <span class="nav-lang-btn is-active" aria-current="page">EN</span>
        ) : (
          <a href="/en/" class="nav-lang-btn" data-lang-switch aria-label="Switch to English">EN</a>
        )}
      </div>
      <div class="nav-social" aria-label={copy.nav.socialLabel}>
        <a href="https://www.linkedin.com/in/liameissner/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg viewBox="0 0 448 512" aria-hidden="true" focusable="false"><path d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3zM447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2-48.29 0-55.69 37.7-55.69 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.69-48.3 87.88-48.3 94 0 111.28 61.9 111.28 142.3V448z"/></svg>
        </a>
        <a href="https://substack.com/@heartfeltfutures" target="_blank" rel="noopener noreferrer" aria-label="Substack">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M22.54 8.24H1.46V5.4h21.08v2.84zM1.46 10.81V24L12 18.11 22.54 24V10.81H1.46zM22.54 0H1.46v2.84h21.08V0z"/></svg>
        </a>
      </div>
    </div>
    <button class="nav-toggle" aria-controls="mobile-menu" aria-expanded="false">{copy.nav.menuLabel}</button>
  </div>
  <nav id="mobile-menu" class="mobile-menu" aria-label={copy.nav.mobileNavLabel}>
    {copy.nav.links.map((l) => <a href={l.href}>{l.label}</a>)}
    <div class="mobile-lang" role="group" aria-label={lang === 'de' ? 'Sprache' : 'Language'}>
      {lang === 'de' ? (
        <span class="nav-lang-btn is-active" aria-current="page">DE</span>
      ) : (
        <a href="/" class="nav-lang-btn" data-lang-switch aria-label="Zur deutschen Version wechseln">DE</a>
      )}
      {lang === 'en' ? (
        <span class="nav-lang-btn is-active" aria-current="page">EN</span>
      ) : (
        <a href="/en/" class="nav-lang-btn" data-lang-switch aria-label="Switch to English">EN</a>
      )}
    </div>
  </nav>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--paper) 92%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--rule-soft);
  }
  .nav-inner {
    display: flex; justify-content: space-between; align-items: center;
    padding: 14px var(--pad-x);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .brand {
    font-family: var(--serif);
    font-size: 18px;
    letter-spacing: 0;
    text-transform: none;
    color: var(--ink);
    white-space: nowrap;
  }
  .nav-right { display: flex; align-items: center; gap: 24px; }
  .nav-links { display: flex; gap: 22px; }
  .nav-links :global(a) { color: var(--ink); }
  .nav-links :global(a:hover) { color: var(--accent); opacity: 1; }
  /* Language toggle — pill pair showing both DE and EN; the active language
     is filled dark, the inactive one is a clickable outline. */
  .nav-lang {
    display: inline-flex;
    align-items: stretch;
    border: 1px solid var(--rule-soft);
    border-radius: 999px;
    overflow: hidden;
    height: 30px;
  }
  .nav-lang-btn {
    display: inline-flex;
    align-items: center;
    padding: 0 12px;
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    line-height: 1;
    transition: background .15s ease, color .15s ease;
  }
  .nav-lang-btn.is-active {
    background: var(--ink);
    color: var(--paper);
    cursor: default;
  }
  .nav-lang :global(a.nav-lang-btn:hover) {
    color: var(--accent);
    opacity: 1;
  }
  /* Round social icons — same treatment as in the footer, scaled down for
     the compact sticky header. */
  .nav-social { display: flex; align-items: center; gap: 8px; }
  .nav-social :global(a) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--ink);
    color: var(--paper);
    transition: background .15s ease;
  }
  .nav-social :global(a:hover) { background: var(--accent); opacity: 1; }
  .nav-social :global(svg) { width: 14px; height: 14px; fill: currentColor; display: block; }
  .nav-toggle {
    display: none;
    background: none;
    border: 1px solid var(--rule-soft);
    padding: 6px 10px;
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
    cursor: pointer;
  }
  .mobile-menu {
    display: none;
    flex-direction: column;
    gap: 14px;
    padding: 14px var(--pad-x) 18px;
    border-top: 1px solid var(--rule-soft);
    background: var(--paper);
  }
  .mobile-menu:global(.open) { display: flex; }
  .mobile-menu :global(a) {
    color: var(--ink);
    font-size: 13px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  /* Mobile menu lang toggle — same pill style as desktop, with a top separator. */
  .mobile-lang {
    display: inline-flex;
    align-items: stretch;
    width: max-content;
    height: 30px;
    margin-top: 8px;
    border: 1px solid var(--rule-soft);
    border-radius: 999px;
    overflow: hidden;
  }
  @media (max-width: 760px) {
    .nav-links { display: none; }
    .nav-right { gap: 14px; }
    .nav-toggle { display: inline-block; }
  }
</style>
