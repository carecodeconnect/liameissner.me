---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Mission from '../components/Mission.astro';
import Pillars from '../components/Pillars.astro';
import About from '../components/About.astro';
import Aktuell from '../components/Aktuell.astro';
import Kontakt from '../components/Kontakt.astro';
import Footer from '../components/Footer.astro';

const lang = 'de';
---
<BaseLayout lang={lang}>
  <Nav lang={lang} />
  <main>
    <Hero lang={lang} />
    <Mission lang={lang} />
    <Pillars lang={lang} />
    <About lang={lang} />
    <Aktuell lang={lang} />
    <Kontakt lang={lang} />
  </main>
  <Footer lang={lang} />
</BaseLayout>
